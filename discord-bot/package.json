{
  "name": "discord-bot",
  "private": "true",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx --env-file=.env ./src/index.ts",
    "lint": "prettier --check . && eslint . --ignore-pattern '**/*.js'",
    "format": "prettier --write .",
    "start": "node index.js"
  },
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "archiver": "^7.0.1",
    "discord.js": "^14.19.3",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@eslint/js": "^9.26.0",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.9"
  }
}
