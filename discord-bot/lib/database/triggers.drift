import 'database.dart';

CREATE TRIGGER users_after_update_trigger
  AFTER UPDATE ON users
BEGIN
  UPDATE users SET last_modified = STRFTIME('%s', 'NOW') WHERE id = NEW.id;
END;

CREATE TRIGGER servers_after_update_trigger
  AFTER UPDATE ON pterodactyl_servers
BEGIN
  UPDATE pterodactyl_servers SET last_modified = STRFTIME('%s', 'NOW') WHERE id = NEW.id;
END;
